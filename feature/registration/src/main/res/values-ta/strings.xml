    <string name="PinEntryScreen__skip_pin_entry_message">உங்கள் பின்னை நினைவில் கொள்ள முடியாவிட்டால், புதிய ஒன்றை உருவாக்கலாம். உங்கள் கணக்கைப் பதிவுசெய்து பயன்படுத்தலாம், ஆனால் உங்கள் சுயவிவரத் தகவல் போன்ற சில சேமித்த அமைப்புகளை இழப்பீர்கள்.</string>
    <!-- Labels the button in the skip dialog that takes the user to create a new PIN. -->
