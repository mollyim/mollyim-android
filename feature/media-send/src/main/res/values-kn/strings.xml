<resources>
  <!-- Dialog title shown when the user tries to leave the image editor with unsaved edits. -->
  <string name="MediaSendDialogs__discard_changes">ಬದಲಾವಣೆಗಳನ್ನು ತ್ಯಜಿಸುವುದೇ?</string>
  <!-- Dialog body explaining that leaving the image editor will discard any edits made to the current photo. -->
  <string name="MediaSendDialogs__youll_lose_any_changes">ಈ ಫೊಟೋಕ್ಕೆ ನೀವು ಮಾಡಿದ ಯಾವುದೇ ಬದಲಾವಣೆಗಳನ್ನು ನೀವು ಕಳೆದುಕೊಳ್ಳುತ್ತೀರಿ.</string>
