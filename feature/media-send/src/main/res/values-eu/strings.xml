  <string name="CameraXFragment_to_capture_photos_and_video_allow_camera_microphone">Argazkiak atera eta bideoak grabatzeko, eman Molly-i kamera eta mikrofonoa erabiltzeko baimena.</string>
  <!-- Text explaining why Signal needs microphone access to take videos -->
  <string name="CameraXFragment_to_capture_videos_with_sound">Soinua duten bideoak grabatzeko, eman Molly-i mikrofonoa erabiltzeko baimena.</string>
