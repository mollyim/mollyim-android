  <string name="CameraXFragment_signal_needs_microphone_access_video">Molly-ek mikrofonoa erabili behar du bideoak grabatzeko</string>
  <!-- Dialog description that explains the steps needed to give camera permission -->
  <string name="CameraXFragment_to_capture_photos">Molly-en argazkiak ateratzeko:</string>
