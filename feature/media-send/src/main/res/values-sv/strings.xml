  <string name="LinkedDeviceScannedDialog__it_looks_like_youre_trying">Det verkar som om du försöker länka en Signal-enhet. Tryck på fortsätt och tryck sedan på Länka en ny enhet och skanna QR-koden igen.</string>
  <!-- The label of a dialog asking the user if they would like to continue to the linked device settings screen. -->
  <string name="LinkedDeviceScannedDialog__device_link_dialog_continue">Fortsätt</string>
