  <string name="UsernameScannedDialog__username_dialog_body">Bắt đầu cuộc trò chuyện với \"%1$s\"</string>
  <!-- The label of a dialog asking the user if they would like to start a chat with a specific user. -->
  <string name="UsernameScannedDialog__username_dialog_go_to_chat_button">Đến cuộc trò chuyện</string>

  <!-- The title of a dialog notifying that the user scanned a QR code that could be used to link a Signal device. -->
  <string name="LinkedDeviceScannedDialog__device_link_dialog_title">Liên kết thiết bị?</string>
