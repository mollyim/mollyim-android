<?xml version="1.0" encoding="UTF-8"?>
<resources>
  <!-- Dialog title shown when the user tries to leave the image editor with unsaved edits. -->
  <string name="MediaSendDialogs__discard_changes">Wijzigingen verwijderen?</string>
  <!-- Dialog body explaining that leaving the image editor will discard any edits made to the current photo. -->
  <string name="MediaSendDialogs__youll_lose_any_changes">Alle wijzigingen die je in deze afbeelding hebt aangebracht zullen verloren gaan.</string>
  <!-- Confirmation button that discards the user\'s image edits. -->
  <string name="MediaSendDialogs__discard">Verwijderen</string>
  <!-- Accessibility label for the row that lets the user add a text message to accompany the media being sent. -->
  <string name="AddAMessageRow__add_a_message">Bericht toevoegen</string>
