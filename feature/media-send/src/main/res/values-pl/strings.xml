  <string name="MediaCaptureScreen__text_story">Relacja tekstowa</string>
  <!-- Video editor play button content description -->
  <string name="VideoEditorHud_play_video_description">Odtwórz wideo</string>

  <!-- CameraFragment -->
  <!-- Toasted when user device does not support video recording -->
  <string name="CameraFragment__video_recording_is_not_supported_on_your_device">Twoje urządzenie nie obsługuje nagrywania wideo</string>

