  <string name="MediaCaptureScreen__text_story">Текстуална прича</string>
  <!-- Video editor play button content description -->
  <string name="VideoEditorHud_play_video_description">Пусти видео</string>

  <!-- CameraFragment -->
  <!-- Toasted when user device does not support video recording -->
  <string name="CameraFragment__video_recording_is_not_supported_on_your_device">Снимање видео записа није подржано на вашем уређају</string>

