  <string name="MediaSendDialogs__youll_lose_any_changes">Utapoteza mabadiliko yoyote uliyofanya kwenye picha hii.</string>
  <!-- Confirmation button that discards the user\'s image edits. -->
  <string name="MediaSendDialogs__discard">Tupa</string>
  <!-- Accessibility label for the row that lets the user add a text message to accompany the media being sent. -->
  <string name="AddAMessageRow__add_a_message">Ongeza ujumbe</string>
