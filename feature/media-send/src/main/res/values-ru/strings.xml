  <string name="MediaSendDialogs__youll_lose_any_changes">Вы потеряете все изменения, которые вы сделали в этой фотографии.</string>
  <!-- Confirmation button that discards the user\'s image edits. -->
  <string name="MediaSendDialogs__discard">Сбросить</string>
  <!-- Accessibility label for the row that lets the user add a text message to accompany the media being sent. -->
  <string name="AddAMessageRow__add_a_message">Добавьте сообщение</string>
