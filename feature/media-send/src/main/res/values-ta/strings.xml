  <!-- Toast dialog explaining why Signal needs camera permissions when scanning QR codes -->
  <string name="CameraXFragment_signal_needs_camera_access_scan_qr_code">QR குறியீடுகளை ஸ்கேன் செய்ய சிக்னலுக்கு கேமரா அணுகல் தேவை</string>
  <!-- Toast dialog explaining why Signal needs microphone permissions -->
  <string name="CameraXFragment_signal_needs_microphone_access_video">வீடியோவை படமெடுக்க, சிக்னலுக்கு மைக்ரோஃபோன் அணுகல் தேவை</string>
  <!-- Dialog description that explains the steps needed to give camera permission -->
