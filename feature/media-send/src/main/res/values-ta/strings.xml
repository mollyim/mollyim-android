  <string name="CameraXFragment_to_scan_qr_codes">QR குறியீடுகளை ஸ்கேன் செய்ய:</string>
  <!-- Error message shown when we try to take a photo, but fail -->
  <string name="CameraXFragment_photo_capture_failed">படத்தை எடுக்க முடியவில்லை. மீண்டும் முயலுங்கள்.</string>
  <!-- Error message shown when we try to take a photo, but fail when trying to process it (convert it into something the user can see). -->
  <string name="CameraXFragment_photo_processing_failed">படத்தைச் செயலாக்க முடியவில்லை. மீண்டும் முயலுங்கள்.</string>
