  <string name="UsernameScannedDialog__username_dialog_body">Magsimula ng chat kay \"%1$s\"</string>
  <!-- The label of a dialog asking the user if they would like to start a chat with a specific user. -->
  <string name="UsernameScannedDialog__username_dialog_go_to_chat_button">Pumunta sa chat</string>

