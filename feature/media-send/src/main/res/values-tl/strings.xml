  <string name="LinkedDeviceScannedDialog__device_link_dialog_title">Gusto mo bang i-link ang iyong device?</string>
  <!-- The body of a dialog notifying that the user scanned a QR code that could be used to link a Signal device. -->
  <string name="LinkedDeviceScannedDialog__it_looks_like_youre_trying">Mukhang sinusubukan mong mag-link ng isang Signal device. I-tap ang continue, tapos i-tap ang \"Mag-link ng Bagong Device\", at subukang i-scan ulit ang QR code.</string>
  <!-- The label of a dialog asking the user if they would like to continue to the linked device settings screen. -->
  <string name="LinkedDeviceScannedDialog__device_link_dialog_continue">Magpatuloy</string>
